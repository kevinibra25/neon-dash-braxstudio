{
  "entities": {
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "A single score entry on the global leaderboard.",
      "type": "object",
      "properties": {
        "playerName": {
          "type": "string",
          "description": "The name of the player."
        },
        "score": {
          "type": "number",
          "description": "The achieved score."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the record was achieved."
        },
        "userId": {
          "type": "string",
          "description": "The unique ID of the player (anonymous or auth)."
        }
      },
      "required": ["playerName", "score", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/leaderboard/{entryId}": {
      "schema": "LeaderboardEntry",
      "description": "Global leaderboard collection."
    }
  }
}
